# --- Background ---
background {
    monitor =
    path = /home/seanyfade/Downloads/wp12710948-4k-grid-wallpapers.jpg   # Supports png, jpg, webp (or color)
    color = rgba(25, 20, 20, 1.0)
    blur_passes = 2 # 0 disables blurring
}

# --- 12-Hour Time Label ---
label {
    monitor =
    text = cmd[update:1000] echo "$(date -"%I:%M %p")"
    color = rgba(0, 255, 0, 1.0) # DOS Green
    font_size = 64
    font_family = JetBrainsMono Nerd Font Mono
    position = 0, 80
    halign = center
    valign = center
}

# --- Date Label ---
label {
    monitor =
    text = cmd[update:1000] echo "$(date +"%A, %B %d")"
    color = rgba(174, 174, 174, 1.0) # Solaris Grey
    font_size = 24
    font_family = JetBrainsMono Nerd Font Mono
    position = 0, 10
    halign = center
    valign = center
}

# --- Beveled Input Field ---
input-field {
    monitor =
    size = 200, 50
    outline_thickness = 3
    dots_size = 0.33
    dots_spacing = 0.15
    dots_center = true
    
    # Solaris Grey / Sky Blue Hybrid Colors
    outer_color = rgb(128, 128, 128) # Darker Grey border
    inner_color = rgb(192, 192, 192) # Solaris Light Grey
    font_color = rgb(0, 0, 0)
    fade_on_empty = true
    placeholder_text = <i>Maybe if you ask nice...</i>
    hide_input = false
    
    position = 0, -80
    halign = center
    valign = center
}
